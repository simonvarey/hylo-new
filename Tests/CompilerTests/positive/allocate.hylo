//! stage:run stdlib:minimal

/// Allocates `bytes` number of bytes on heap.
///
/// - Returns the memory address as an integer or `null` if allocation failed.
/// - Precondition: `bytes` must be non-negative.
@extern("malloc_shim")
fun malloc(bytes: Int) -> Int

/// Frees the memory at the given address.
///
/// Precondition: `ptr` must point to a valid memory address allocated by `malloc`.
@extern("free_shim")
fun free(ptr: Int) -> Void

public fun main() {
  let five = 5
  print(five)
  
  let ptr = malloc(five)
  let ptr2 = malloc(five)
  print(ptr)
  print(ptr2)
  free(ptr)
  free(ptr2)
  print(99)
}
